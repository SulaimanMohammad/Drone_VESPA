+// Function to sort an array of integers
+void sortArray(int arr[], int numElements)
+{
+    for (int i = 0; i < numElements - 1; i++)
+    {
+        for (int j = 0; j < numElements - i - 1; j++)
+        {
+            if (arr[j] > arr[j + 1])
+            {
+                // Swap arr[j] and arr[j+1]
+                int temp = arr[j];
+                arr[j] = arr[j + 1];
+                arr[j + 1] = temp;
+            }
+        }
+    }
+}
